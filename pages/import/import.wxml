<view class="page">
  <view class="section">
    <view class="title">新建材料</view>
    <view class="subtitle">新材料会保存到未归类材料；有音频就播放，没有音频就阅读。</view>
  </view>

  <view class="section panel stack">
    <input
      class="text-input"
      value="{{title}}"
      bindinput="onTitleInput"
      placeholder="材料标题"
      placeholder-class="input-placeholder"
    />
    <textarea
      class="content-input"
      value="{{content}}"
      bindinput="onContentInput"
      placeholder="粘贴英文句子、段落或文章"
      placeholder-class="input-placeholder"
      auto-height="{{false}}"
      maxlength="-1"
    />
  </view>

  <view class="section panel audio-picker">
    <view class="audio-picker-copy">
      <view class="audio-picker-title">音频</view>
      <view class="audio-picker-meta">{{audioFileName || '可选，从微信会话文件选择 mp3、m4a、wav'}}</view>
    </view>
    <view class="audio-picker-actions">
      <view class="audio-action" bindtap="chooseAudio">{{audioFileName ? '重选音频' : '选择音频'}}</view>
      <view wx:if="{{audioFileName}}" class="audio-action muted" bindtap="clearAudio">清除</view>
    </view>
  </view>

  <van-button color="#38bdf8" block loading="{{isSaving}}" disabled="{{isSaving}}" bindtap="saveMaterial">保存到未归类材料</van-button>
</view>
