.practice-index-page {
  padding-bottom: 48rpx;
}

.hero {
  padding: 24rpx 0 8rpx;
}

.practice-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.practice-entry {
  display: flex;
  min-height: 128rpx;
  min-width: 0;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
  border: 1rpx solid #bae6fd;
  border-radius: 8rpx;
  color: #0284c7;
  background: #ffffff;
}

.entry-body {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  gap: 6rpx;
}

.entry-title {
  color: #0284c7;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.entry-meta {
  color: #667085;
  font-size: 24rpx;
  line-height: 34rpx;
  overflow-wrap: break-word;
}
