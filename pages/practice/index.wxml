<view class="page practice-index-page">
  <view class="section hero">
    <view class="title">{{modeLabel}}练习</view>
    <view class="subtitle">从已有音频材料中随机播放，默认盲听，按需查看原文。</view>
  </view>

  <view class="section practice-grid">
    <view class="practice-entry" bindtap="startAll">
      <van-icon name="exchange" />
      <view class="entry-body">
        <text class="entry-title">全部随机</text>
        <text class="entry-meta">{{allDescription}}</text>
      </view>
    </view>
    <view class="practice-entry" bindtap="openCategories">
      <van-icon name="cluster-o" />
      <view class="entry-body">
        <text class="entry-title">分类随机</text>
        <text class="entry-meta">选择一个分类练习</text>
      </view>
    </view>
    <view class="practice-entry" bindtap="openGroups">
      <van-icon name="bookmark-o" />
      <view class="entry-body">
        <text class="entry-title">练习组</text>
        <text class="entry-meta">{{groupDescription}}</text>
      </view>
    </view>
  </view>
</view>
