.workspace-page {
  padding-top: 44rpx;
}

.hero {
  padding: 36rpx 0 28rpx;
}

.action-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.action-card {
  display: flex;
  min-width: 0;
  min-height: 136rpx;
  align-items: center;
  gap: 22rpx;
  padding: 26rpx;
  border: 1rpx solid #bae6fd;
  border-radius: 8rpx;
  color: #0284c7;
  background: #ffffff;
}

.action-body {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.action-title {
  color: #0284c7;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.action-description {
  color: #667085;
  font-size: 24rpx;
  line-height: 34rpx;
  overflow-wrap: break-word;
}
