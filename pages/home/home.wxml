<view class="page home-page">
  <view class="section hero">
    <view class="title">每日英语听写</view>
    <view class="subtitle">选择测试通道或云端通道，进入资源、新建和听写练习。</view>
  </view>

  <view class="section workspace-grid">
    <view
      wx:for="{{workspaces}}"
      wx:key="kind"
      class="workspace-card"
      data-mode="{{item.mode}}"
      bindtap="openWorkspace"
    >
      <van-icon name="{{item.icon}}" />
      <view class="workspace-body">
        <text class="workspace-title">{{item.name}}</text>
        <text class="workspace-description">{{item.description}}</text>
      </view>
    </view>
  </view>
</view>
